<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" SystemWatcher"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Surveillance des événements système"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔴 Surveillance réseau : INACTIVE"
        android:textSize="15sp"
        android:textColor="#333333"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnToggleReceiver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activer surveillance"
        android:backgroundTint="#16213E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSendCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Envoyer signal custom"
        android:backgroundTint="#0F3460"
        android:textColor="#FFFFFF"/>

</LinearLayout>